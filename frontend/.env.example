# ============================================================
# ShieldPay Frontend — Environment Variables
# ============================================================
# Copy to .env.local for local dev, or set in Vercel for production

# Backend API URL
# Local: http://localhost:8000
# Production: https://your-backend.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Stripe publishable key — https://dashboard.stripe.com/apikeys
# Use pk_test_ for development, pk_live_ for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# NextAuth — generate secret with:
# openssl rand -base64 48
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret
