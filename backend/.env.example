# ============================================================
# ShieldPay Backend — Environment Variables
# ============================================================
# Copy to .env for local dev, or set in Railway/Render for production

ENVIRONMENT=development  # development | staging | production

# Database
# Local: postgresql+asyncpg://shieldpay:shieldpay_dev@localhost:5432/shieldpay
# Railway: auto-provided as DATABASE_URL (change prefix to postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://shieldpay:shieldpay_dev@localhost:5432/shieldpay

# Stripe — https://dashboard.stripe.com/apikeys
# Use sk_test_ for development, sk_live_ for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Auth — MUST be unique per environment. Generate with:
# python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Frontend URL — no trailing slash
FRONTEND_URL=http://localhost:3000

# SendGrid — https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# Sentry — https://sentry.io → Project → Client Keys (DSN)
SENTRY_DSN=
